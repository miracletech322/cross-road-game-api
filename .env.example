# --- Server ---
NODE_ENV=development
PORT=3000

# --- Database ---
MONGODB_URI=mongodb://127.0.0.1:27017/cross-road-game-api

# --- Auth (JWT) ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
PASSWORD_SALT_ROUNDS=10

# --- API docs (OpenAPI "servers" base URL; use root, not /api/docs) ---
SWAGGER_SERVER_URL=http://localhost:3000

# --- Stripe (server uses secret key only; never ship sk_ in Unity or web builds) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional reference (pk_…); Unity Checkout redirect flow does not require this on the API
STRIPE_PUBLISHABLE_KEY=

# Stripe success/cancel redirect base (Unity deep link / universal link / game URL).
# Same value can be set as GAME_CLIENT_URL (optional alias).
FRONTEND_URL=http://localhost:3001
GAME_CLIENT_URL=

# Paths appended to FRONTEND_URL / GAME_CLIENT_URL for Stripe redirects
STRIPE_SUCCESS_PATH=/payment/success
STRIPE_CANCEL_PATH=/payment/cancel

# Credits pricing (integer cents per 1 credit; total = credits * CREDIT_PRICE_CENTS_PER_UNIT)
CREDIT_PRICE_CENTS_PER_UNIT=1
CREDIT_PURCHASE_MIN=1
CREDIT_PURCHASE_MAX=100000
